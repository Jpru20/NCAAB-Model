def update_final_scores():

    print("\n--- CHECKING FOR COMPLETED GAMES (LAST 24 HOURS) ---")

    url = f'https://api.the-odds-api.com/v4/sports/{SPORT_KEY}/scores'

    params = {

        'api_key': ODDS_API_KEY,

        'daysFrom': 1

    }

    

    try:

        res = requests.get(url, params=params).json()

        updates = []

        

        for game in res:

            if not game.get('completed', False): continue

            scores = game.get('scores', [])

            if not scores: continue

            

            h_score, a_score = 0, 0

            for s in scores:

                if s['name'] == game['home_team']: h_score = int(s['score'])

                if s['name'] == game['away_team']: a_score = int(s['score'])



            date_str = game['commence_time'][:10]

            game_id = f"{date_str}_NCAAB_{game['away_team']}_{game['home_team']}".replace(" ", "").replace(".","")

            updates.append((h_score, a_score, game_id))

            

        if updates:

            conn = psycopg2.connect(DB_URL)

            cur = conn.cursor()

            sql = """

            UPDATE "predictions_2.0"

            SET home_score = %s, away_score = %s, updated_at = CURRENT_TIMESTAMP

            WHERE game_id = %s;

            """

            cur.executemany(sql, updates)

            conn.commit()

            cur.close()

            conn.close()

            print(f"   > SUCCESS: Updated final scores for {len(updates)} games.")

        else:

            print("   > No new completed games found to update.")

            

    except Exception as e:

        print(f"   > Score Update Error: {e}")



